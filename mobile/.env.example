# API Keys - Do NOT commit actual values to version control
# Get your Gemini API key from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Get your OpenRouter API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Instructions:
# 1. Copy this file to .env (do NOT commit .env to git)
# 2. Replace the placeholders above with your actual API keys
# 3. Keep this .env.example file with placeholders for version control
